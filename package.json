{
  "name": "screenshot-tool",
  "version": "2.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun dev-server.js & bun run build --watch",
    "build": "bun build.js && bun build --target=browser --outdir=dist --define:process.env.NODE_ENV='\"production\"' sidepanel.html background.js content.js",
    "package": "bun run build && cd dist && zip -r ../screenshot-tool-extension.zip *",
    "release": "bumpp package.json manifest.json"
  },
  "dependencies": {
    "marked": "^15.0.11",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bumpp": "^10.4.1"
  },
  "peerDependencies": {
    "typescript": "^5.8.2"
  }
}